<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="page-content">
  <section class="hero" style="padding-bottom:60px;">
    <div class="container">
      <div class="hero-content fade-in">
        <span class="overline">Contact</span>
        <h1>Let's start a <span class="accent">conversation</span></h1>
        <p class="lead">Whether you're exploring AI for the first time or ready to scale — we'd love to hear about where you are and where you want to go.</p>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h3>Get in Touch</h3>
          <p>Every engagement starts with a conversation. No pitch decks. No pressure. Just a real discussion about your firm, your challenges, and whether we're the right fit.</p>

          <div class="contact-method">
            <div class="method-icon">&#128197;</div>
            <div>
              <div class="method-label">Schedule a Call</div>
              <div class="method-value"><a href="<%= links.booking %>">Book a time that works for you</a></div>
            </div>
          </div>

          <div class="contact-method">
            <div class="method-icon">&#9993;</div>
            <div>
              <div class="method-label">Email</div>
              <div class="method-value"><a href="mailto:ore@orphil.co">ore@orphil.co</a></div>
            </div>
          </div>

          <div class="contact-method">
            <div class="method-icon">&#128240;</div>
            <div>
              <div class="method-label">Follow</div>
              <div class="method-value"><a href="<%= links.substack %>" target="_blank" rel="noopener">orephillips.substack.com</a></div>
            </div>
          </div>

          <div class="contact-method">
            <div class="method-icon">&#128172;</div>
            <div>
              <div class="method-label">Community</div>
              <div class="method-value"><a href="<%= links.slack %>" target="_blank" rel="noopener">AI in Finance Slack</a></div>
            </div>
          </div>
        </div>

        <div>
          <div class="card" style="padding:40px;">
            <h3 style="margin-bottom:8px;">What to expect</h3>
            <p style="margin-bottom:24px;">A 30-minute conversation where we'll cover:</p>
            <ul style="list-style:none;padding:0;">
              <li style="padding:10px 0;border-bottom:1px solid var(--border-subtle);color:var(--text-secondary);">
                <strong style="color:var(--text-primary);">1. Where you are</strong><br>
                Your current AI maturity, tools, and team readiness
              </li>
              <li style="padding:10px 0;border-bottom:1px solid var(--border-subtle);color:var(--text-secondary);">
                <strong style="color:var(--text-primary);">2. Where you want to go</strong><br>
                Your goals, timeline, and what success looks like
              </li>
              <li style="padding:10px 0;border-bottom:1px solid var(--border-subtle);color:var(--text-secondary);">
                <strong style="color:var(--text-primary);">3. How we might help</strong><br>
                Honest assessment of whether Orphil is the right partner
              </li>
              <li style="padding:10px 0;color:var(--text-secondary);">
                <strong style="color:var(--text-primary);">4. Next steps</strong><br>
                Clear path forward — or a referral if we're not the right fit
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
