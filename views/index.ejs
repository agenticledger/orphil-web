<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="page-content">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-content fade-in">
        <span class="overline">Ore Phillips Advisory</span>
        <h1>Your <span class="accent">AI Transformation</span> Partner for Finance</h1>
        <p class="lead">We help finance, accounting, and consulting firms adopt AI with confidence — from strategy and training to deployed agents and applications.</p>
        <div class="hero-actions">
          <a href="/contact" class="btn btn-primary">Start a Conversation &rarr;</a>
          <a href="/services" class="btn btn-secondary">Explore Services</a>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do -->
  <section>
    <div class="container">
      <div class="section-header">
        <span class="overline">What We Do</span>
        <h2>Three pillars of AI transformation</h2>
        <p>Every engagement is built around where you are today and where you need to go.</p>
      </div>

      <div class="card-grid-3">
        <div class="card">
          <div class="card-icon">&#9670;</div>
          <h3>Strategy & Planning</h3>
          <p>Assessment, training, roadmaps, and resourcing. Know where you're going before you build.</p>
          <a href="/services#strategy" style="display:inline-block;margin-top:16px;font-weight:600;font-size:0.9rem;">Learn more &rarr;</a>
        </div>
        <div class="card">
          <div class="card-icon">&#9733;</div>
          <h3>Advisory</h3>
          <p>Ongoing expert presence — the AI transformation partner you call when it matters. Governance, oversight, and counsel.</p>
          <a href="/services#advisory" style="display:inline-block;margin-top:16px;font-weight:600;font-size:0.9rem;">Learn more &rarr;</a>
        </div>
        <div class="card">
          <div class="card-icon">&#9881;</div>
          <h3>Execution</h3>
          <p>Hands-on delivery. AI agents, applications, and transformation management — built and deployed.</p>
          <a href="/services#execution" style="display:inline-block;margin-top:16px;font-weight:600;font-size:0.9rem;">Learn more &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Who We Serve -->
  <section>
    <div class="container">
      <div class="section-header">
        <span class="overline">Who We Serve</span>
        <h2>Built for finance professionals navigating AI</h2>
      </div>

      <div class="card-grid">
        <div class="card">
          <h3>In-House Finance Teams</h3>
          <p>CFOs, controllers, and finance leaders inside companies — build AI capabilities across your function. From individual productivity to team-wide automation.</p>
        </div>
        <div class="card">
          <h3>Advisory & Consulting Firms</h3>
          <p>Accounting firms, fractional CFO practices, and finance consultancies — build AI capabilities internally <em>and</em> deliver them to your clients.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Belief -->
  <section>
    <div class="container">
      <div class="belief-block">
        <blockquote>"<%= belief %>"</blockquote>
        <cite>— The Orphil Belief</cite>
      </div>
      <p style="max-width:680px;font-size:1.05rem;">The goal of every engagement is to leave you more capable, not more dependent. We build toward our own redundancy.</p>
    </div>
  </section>

  <!-- Product Teaser -->
  <section>
    <div class="container">
      <div class="section-header">
        <span class="overline">Product</span>
        <h2>myaiforone</h2>
        <p>A local AI operating system — specialized AI agents running entirely on your computer, powered by your own AI subscription. Zero platform fees. Full data privacy.</p>
      </div>
      <a href="/product" class="btn btn-primary">Learn About myaiforone &rarr;</a>
    </div>
  </section>

  <!-- CTA -->
  <section style="text-align:center;">
    <div class="container">
      <h2>Ready to start your AI transformation?</h2>
      <p style="margin:16px auto 32px;">Let's talk about where you are and where you want to go.</p>
      <a href="/contact" class="btn btn-primary">Schedule a Conversation &rarr;</a>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
